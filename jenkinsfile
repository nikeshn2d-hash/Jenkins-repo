                echo "Running Python script"
                sh 'python3 print.py'
            }
        }

        stage('Test') {
            steps {
                echo "Test Stage"
            }
        }

        stage('Deploy') {
            steps {
                echo "Deploy Stage"
            }
        }
    }
}
